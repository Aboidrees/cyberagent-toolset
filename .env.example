# ── Example environment variables ────────────────────────────────────────────
# Copy to .env (gitignored) and fill in as needed. Everything here is optional —
# the tool runs fully keyless; these only enable extra enrichment / integrations.

# ── Webhook / notifications (Phase 3) ────────────────────────────────────────
# After a run, a summary is POSTed to these endpoints when findings meet the
# severity threshold. Leave unset to disable.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# WEBHOOK_URL=https://example.com/recon-webhook
# Comma list of severities that trigger a notification (default: high,critical).
# Use "all" to notify on every completed run.
# NOTIFY_ON_SEVERITY=high,critical

# ── Optional API keys for key-gated executors ────────────────────────────────
# ip.intel abuse-reputation enrichment (AbuseIPDB). Without it, ASN/IP intel
# still works; only the reputation block is skipped.
# ABUSEIPDB_API_KEY=yourkeyhere
# shodan.host (no-op without a key).
# SHODAN_API_KEY=yourkeyhere
# vuln.cve_lookup works keyless; a key only raises the NVD rate limit.
# NVD_API_KEY=yourkeyhere
# Reserved for future executors.
# SECURITYTRAILS_API_KEY=yourkeyhere
