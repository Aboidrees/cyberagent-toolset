# ─────────────────────────────────────────────────────────────────────────────
# mcp-recon-runner environment configuration
#
# Copy this file to `.env` (gitignored) and fill in what you need. EVERYTHING
# here is OPTIONAL — the tool runs fully keyless. These values only enable extra
# enrichment (some executors) or integrations (notifications).
# ─────────────────────────────────────────────────────────────────────────────


# ── Notifications: Slack incoming webhook ────────────────────────────────────
# What:  Posts a run summary to a Slack channel when findings meet the threshold.
# Get it: https://api.slack.com/messaging/webhooks
#         Create a Slack app → "Incoming Webhooks" → Add to a channel → copy URL.
# Cost:  FREE (included with any Slack workspace).
SLACK_WEBHOOK_URL=

# ── Notifications: generic webhook ───────────────────────────────────────────
# What:  POSTs the full run summary as JSON to any HTTP endpoint you control
#        (Teams connector, custom server, automation, etc.).
# Get it: Your own endpoint URL — no third-party account needed.
# Cost:  FREE (self-hosted).
WEBHOOK_URL=

# ── Notification severity gate ───────────────────────────────────────────────
# Comma-separated severities that trigger a notification. Use "all" to notify on
# every completed run. Default when unset: high,critical
NOTIFY_ON_SEVERITY=high,critical


# ── AbuseIPDB — ip.intel abuse-reputation enrichment ─────────────────────────
# What:  Adds IP abuse-confidence score + report history to `ip.intel`. Without
#        it, ASN/BGP/country/hosting intel still works; only reputation is skipped.
# Get it: https://www.abuseipdb.com/register  →  Account → API → "Create Key".
# Cost:  FREE tier (1,000 checks/day). Paid plans raise the daily limit.
ABUSEIPDB_API_KEY=

# ── Shodan — shodan.host lookups ─────────────────────────────────────────────
# What:  Enables `shodan.host` (indexed ports, banners, CVEs, tags). Without a
#        key the executor is a no-op note and never fails a run.
# Get it: https://account.shodan.io  →  sign up → copy "API Key" from the account
#        page.
# Cost:  PAID. A one-time Membership (often ~$49, discounted during sales) unlocks
#        API access; the free account's key has very limited query credits.
SHODAN_API_KEY=

# ── NVD — vuln.cve_lookup rate-limit boost ───────────────────────────────────
# What:  `vuln.cve_lookup` works WITHOUT a key. A key only raises the NVD API
#        rate limit (5 → 50 requests per 30s), useful for large CVE sweeps.
# Get it: https://nvd.nist.gov/developers/request-an-api-key  (emailed instantly).
# Cost:  FREE.
NVD_API_KEY=

# ── SecurityTrails — passive DNS history ─────────────────────────────────────
# What:  Enables securitytrails.subdomains and securitytrails.dns_history
#        (historical subdomains + A-record timelines).
# Get it: https://securitytrails.com  →  dashboard → API → copy key.
# Cost:  FREE tier (limited monthly queries). Paid plans for higher volume.
SECURITYTRAILS_API_KEY=

# ── Censys — internet-wide host data ─────────────────────────────────────────
# What:  Enables censys.host (services, software, ASN, location for an IP).
#        Uses HTTP basic auth with an API ID + secret.
# Get it: https://search.censys.io  →  Account → API Keys.
# Cost:  FREE tier (limited queries). Paid plans for higher volume.
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── GitHub token — code-search leaks ─────────────────────────────────────────
# What:  Enables github.leaks (search public GitHub code for your domain).
#        Any classic or fine-grained token with public read works.
# Get it: https://github.com/settings/tokens
# Cost:  FREE.
GITHUB_TOKEN=

# ── Hunter.io — email harvesting ─────────────────────────────────────────────
# What:  Enables hunter.emails (email addresses, address pattern, and
#        organization Hunter.io associates with a domain).
# Get it: https://hunter.io/api-keys
# Cost:  FREE tier (limited monthly searches). Paid plans for higher volume.
HUNTER_API_KEY=

# ── GreyNoise — greynoise.ip noise/malicious classification ──────────────────
# What:  Enables `greynoise.ip` — is an IP internet background-noise (mass
#        scanners) or targeted, plus RIOT known-good-service flagging. Without a
#        key the executor is a no-op note and never fails a run.
# Get it: https://www.greynoise.io  →  sign up → Account → API key (Community).
# Cost:  FREE community key.
GREYNOISE_API_KEY=

# ── VirusTotal — virustotal.lookup reputation ────────────────────────────────
# What:  Enables `virustotal.lookup` — how many of ~90 vendors flag an IP/domain
#        malicious, plus community reputation. No-op without a key.
# Get it: https://www.virustotal.com  →  sign up → profile → API Key.
# Cost:  FREE public key (rate-limited). Paid plans for higher volume.
VIRUSTOTAL_API_KEY=

# ── BinaryEdge — binaryedge.host internet-scan data ──────────────────────────
# What:  Enables `binaryedge.host` — open ports + observed services for an IP
#        from BinaryEdge's internet scans (a Shodan/Censys alternative source).
# Get it: https://www.binaryedge.io  →  sign up → Account → API access.
# Cost:  FREE tier (limited monthly queries). Paid plans for higher volume.
BINARYEDGE_API_KEY=

# ── Intelligence X — intelx.search leak/OSINT corpus ─────────────────────────
# What:  Enables `intelx.search` — records referencing a domain/selector across
#        leak, paste, darknet and other OSINT sources. No-op without a key.
# Get it: https://intelx.io  →  sign up → Developer tab → API key.
# Cost:  FREE key (limited). Paid plans for full access.
INTELX_API_KEY=

# ── Nuclei (no key — a binary) ───────────────────────────────────────────────
# nuclei.scan needs the `nuclei` binary, not a key:
#   https://github.com/projectdiscovery/nuclei  (brew install nuclei)

# ── Headless browser (no key — a binary) ─────────────────────────────────────
# web.screenshot drives an installed Chrome/Chromium/Edge via --headless.
# It auto-detects common locations; set CHROME_PATH to override the executable.
#   e.g. CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_PATH=
