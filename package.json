{
  "name": "cyberagent-toolset",
  "version": "0.22.0",
  "description": "CyberAgentToolSet (CATS) — an MCP server + CLI that orchestrates authorized security assessments across the attack lifecycle via installable extensions.",
  "type": "module",
  "license": "MIT",
  "author": "Muhammad Yousif (Aboidrees)",
  "homepage": "https://github.com/Aboidrees/cyberagent-toolset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aboidrees/cyberagent-toolset.git"
  },
  "bugs": {
    "url": "https://github.com/Aboidrees/cyberagent-toolset/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "cyberagent": "src/index.js",
    "cyberagent-mcp": "src/mcp-server.js"
  },
  "imports": {
    "#sdk": "./src/sdk.js"
  },
  "files": [
    "src",
    "extensions",
    "playbooks",
    "watchlists",
    "schemas",
    "templates",
    "docs",
    ".env.example",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "about.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "security",
    "reconnaissance",
    "pentest",
    "cyberagent",
    "cyberagent-toolset"
  ],
  "scripts": {
    "mcp": "node ./src/mcp-server.js",
    "start": "node ./src/index.js",
    "recon": "node ./src/index.js -p ./playbooks/web-basic-recon.yaml",
    "recon:basic": "node ./src/index.js -p ./playbooks/web-basic-recon.yaml",
    "recon:comprehensive": "node ./src/index.js -p ./playbooks/comprehensive-web-recon.yaml",
    "recon:security": "node ./src/index.js -p ./playbooks/web-security-recon.yaml",
    "recon:api": "node ./src/index.js -p ./playbooks/api-cloud-recon.yaml",
    "recon:quick": "node ./src/index.js -p ./playbooks/quick-web-recon.yaml",
    "selftest": "node ./src/index.js -p ./playbooks/all-tools-selftest.yaml",
    "test:network": "node ./src/index.js -p ./playbooks/network-connectivity-test.yaml",
    "diff": "node ./src/index.js diff",
    "watch": "node ./src/index.js watch",
    "schedule": "node ./src/index.js schedule",
    "report": "node ./src/index.js report",
    "help": "node ./src/index.js --help",
    "validate": "node ./scripts/ci-validate.mjs",
    "eval": "node ./scripts/eval.mjs",
    "prepublishOnly": "node ./scripts/ci-validate.mjs",
    "eval:llm": "node ./scripts/eval-llm.mjs",
    "dashboard": "node ./src/index.js dashboard",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.2",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "whois-json": "^2.1.0",
    "yargs": "^17.7.2"
  }
}
